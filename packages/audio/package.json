{
  "name": "@react-piano-keyboard/audio",
  "version": "0.1.0",
  "description": "Audio types, defaults, presets, and synth hooks for react-piano-keyboard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/audio.d.ts",
  "exports": {
    ".": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.mjs",
      "require": "./dist/defaults.cjs"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-piano-keyboard/music": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "keywords": [
    "web-audio",
    "synthesizer",
    "music",
    "react"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejnkns/react-piano-keyboard.git",
    "directory": "packages/audio"
  },
  "homepage": "https://github.com/ejnkns/react-piano-keyboard#readme",
  "bugs": "https://github.com/ejnkns/react-piano-keyboard/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1"
  }
}
