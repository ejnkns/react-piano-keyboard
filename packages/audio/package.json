{
  "name": "@react-piano-keyboard/audio",
  "version": "0.1.0",
  "description": "Audio types, defaults, presets, and synth hooks for react-piano-keyboard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.mjs",
      "require": "./dist/defaults.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-piano-keyboard/music": "*"
  },
  "license": "MIT",
  "devDependencies": {
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1"
  }
}
