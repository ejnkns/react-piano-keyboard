{
  "name": "react-piano-keyboard",
  "version": "0.1.0",
  "description": "A React piano keyboard component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/react-piano-keyboard.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "require": "./dist/hooks.cjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.mjs",
      "require": "./dist/components.cjs"
    },
    "./music": {
      "types": "./dist/music.d.ts",
      "import": "./dist/music.mjs",
      "require": "./dist/music.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./styles.css": "./dist/react-piano-keyboard.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@react-piano-keyboard/audio": "*",
    "@react-piano-keyboard/controls": "*",
    "@react-piano-keyboard/music": "*",
    "@react-piano-keyboard/piano-keyboard": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^22.0.0",
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^0.31.0"
  },
  "keywords": [
    "piano",
    "synth",
    "synthesizer",
    "web-audio",
    "web-audio-api",
    "react",
    "keyboard",
    "music"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejnkns/react-piano-keyboard"
  }
}
