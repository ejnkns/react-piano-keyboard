{
  "name": "react-piano-keyboard",
  "version": "0.1.0",
  "description": "A batteries-included React piano and composable Web Audio toolkit",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/react-piano-keyboard.d.ts",
  "exports": {
    ".": {
      "types": "./dist/react-piano-keyboard.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./piano": {
      "types": "./dist/piano.d.ts",
      "import": "./dist/piano.mjs",
      "require": "./dist/piano.cjs"
    },
    "./piano-keyboard": {
      "types": "./dist/piano-keyboard.d.ts",
      "import": "./dist/piano-keyboard.mjs",
      "require": "./dist/piano-keyboard.cjs"
    },
    "./music": {
      "types": "./dist/music.d.ts",
      "import": "./dist/music.mjs",
      "require": "./dist/music.cjs"
    },
    "./audio": {
      "types": "./dist/audio.d.ts",
      "import": "./dist/audio.mjs",
      "require": "./dist/audio.cjs"
    },
    "./audio/defaults": {
      "types": "./dist/audio-defaults.d.ts",
      "import": "./dist/audio-defaults.mjs",
      "require": "./dist/audio-defaults.cjs"
    },
    "./audio/presets": {
      "types": "./dist/audio-presets.d.ts",
      "import": "./dist/audio-presets.mjs",
      "require": "./dist/audio-presets.cjs"
    },
    "./controls": {
      "types": "./dist/controls.d.ts",
      "import": "./dist/controls.mjs",
      "require": "./dist/controls.cjs"
    },
    "./controls/primitives": {
      "types": "./dist/control-primitives.d.ts",
      "import": "./dist/control-primitives.mjs",
      "require": "./dist/control-primitives.cjs"
    },
    "./visualizers": {
      "types": "./dist/visualizers.d.ts",
      "import": "./dist/visualizers.mjs",
      "require": "./dist/visualizers.cjs"
    },
    "./styles.css": "./dist/react-piano-keyboard.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@react-piano-keyboard/audio": "^0.1.0",
    "@react-piano-keyboard/controls": "^0.1.0",
    "@react-piano-keyboard/music": "^0.1.0",
    "@react-piano-keyboard/piano-keyboard": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^22.0.0",
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^0.31.0"
  },
  "keywords": [
    "piano",
    "synth",
    "synthesizer",
    "web-audio",
    "web-audio-api",
    "react",
    "keyboard",
    "music"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejnkns/react-piano-keyboard.git",
    "directory": "packages/react-piano-keyboard"
  },
  "homepage": "https://github.com/ejnkns/react-piano-keyboard#readme",
  "bugs": "https://github.com/ejnkns/react-piano-keyboard/issues",
  "publishConfig": {
    "access": "public"
  }
}
