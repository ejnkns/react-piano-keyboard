  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-piano-keyboard/shared": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1"
  }
