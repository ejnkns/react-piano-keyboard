{
  "name": "@react-piano-keyboard/piano-keyboard",
  "version": "0.1.0",
  "description": "Controlled React piano keyboard rendering and computer-key bindings",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/piano-keyboard.d.ts",
  "exports": {
    ".": {
      "types": "./dist/piano-keyboard.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/piano-keyboard.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-piano-keyboard/music": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "keywords": [
    "react",
    "piano",
    "keyboard",
    "music"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejnkns/react-piano-keyboard.git",
    "directory": "packages/piano-keyboard"
  },
  "homepage": "https://github.com/ejnkns/react-piano-keyboard#readme",
  "bugs": "https://github.com/ejnkns/react-piano-keyboard/issues",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "postcss-load-config": "^5.1.0",
    "tailwindcss": "^4.3.1",
    "vitest": "^0.31.0"
  }
}
