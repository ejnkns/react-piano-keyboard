{
  "name": "@react-piano-keyboard/piano-keyboard",
  "version": "0.1.0",
  "description": "Uncontrolled piano keyboard component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
