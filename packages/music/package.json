{
  "name": "@react-piano-keyboard/music",
  "version": "0.1.0",
  "description": "Music and pitch utilities for react-piano-keyboard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/music.d.ts",
  "exports": {
    ".": {
      "types": "./dist/music.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "music",
    "pitch",
    "frequency",
    "piano"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ejnkns/react-piano-keyboard.git",
    "directory": "packages/music"
  },
  "homepage": "https://github.com/ejnkns/react-piano-keyboard#readme",
  "bugs": "https://github.com/ejnkns/react-piano-keyboard/issues",
  "publishConfig": {
    "access": "public"
  }
}
